{
  "name": "app",
  "private": "true",
  "dependencies": {
    "@apollo/client": "^3.8.1",
    "@hotwired/turbo-rails": "^7.3.0",
    "@rollup/plugin-node-resolve": "^15.1.0",
    "@tailwindcss/forms": "^0.5.4",
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.14",
    "classnames": "^2.3.2",
    "daisyui": "^4.6.0",
    "esbuild": "^0.18.17",
    "formik": "^2.4.3",
    "framer-motion": "^10.15.1",
    "graphql": "^16.7.1",
    "lodash": "^4.17.21",
    "postcss": "^8.4.27",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-import": "^15.1.0",
    "postcss-nested": "^6.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router": "^6.14.2",
    "react-router-dom": "^6.14.2",
    "tailwindcss": "^3.3.3",
    "vite-plugin-environment": "^1.1.3",
    "vite-plugin-full-reload": "^1.0.5",
    "vite-tsconfig-paths": "^4.2.0"
  },
  "scripts": {
    "build": "esbuild ./frontend/*.* --bundle --sourcemap --outdir=app/assets/builds --public-path=/assets",
    "build:css": "tailwindcss --postcss -i ./frontend/stylesheets/application.css -o ./app/assets/builds/application.css",
    "prettier": "prettier -w .prettierrc",
    "eslint": "eslint --color --ext .js,.jsx,.ts,.tsx,.graphql",
    "eslint-fix": "eslint --color --fix --ext .js,.jsx,.ts,.tsx,.graphql",
    "tsc": "tsc",
    "codegen": "yarn codegen:clean && yarn codegen:graphql_codegen",
    "codegen:clean": "find frontend -type d -name __generated__ -print0 | xargs -0 rm -rf && mkdir -p frontend/graphql/__generated__",
    "codegen:graphql_codegen": "yarn graphql-codegen --config codegen.ts"
  },
  "devDependencies": {
    "@babel/core": "^7.22.9",
    "@graphql-codegen/cli": "5.0.0",
    "@graphql-codegen/client-preset": "4.1.0",
    "@graphql-codegen/fragment-matcher": "^5.0.0",
    "@graphql-codegen/near-operation-file-preset": "^2.5.0",
    "@graphql-codegen/typescript-apollo-client-helpers": "^2.2.6",
    "@graphql-codegen/typescript-operations": "^4.0.1",
    "@graphql-codegen/typescript-react-apollo": "^3.3.7",
    "@swc/core": "^1.3.72",
    "@trivago/prettier-plugin-sort-imports": "^4.2.0",
    "@types/lodash": "^4.14.197",
    "@types/node": "^20.4.5",
    "@types/react": "^18.2.18",
    "@types/react-dom": "^18.2.7",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^6.2.1",
    "@typescript-eslint/parser": "^6.2.1",
    "@vitejs/plugin-react-swc": "^3.3.2",
    "eslint": "^8.0.1",
    "eslint-config-prettier": "^8.9.0",
    "eslint-config-standard-with-typescript": "^37.0.0",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-n": "^15.0.0 || ^16.0.0 ",
    "eslint-plugin-promise": "^6.0.0",
    "eslint-plugin-react": "^7.33.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "*",
    "vite": "^4.4.2",
    "vite-plugin-ruby": "^3.2.2"
  },
  "engines": {
    "node": ">=16"
  }
}
