<div class="flex flex-col justify-center object-center h-full bg-gray-100 w-full py-16 px-4">
    <div class="flex flex-col items-center justify-center">
       <%= image_tag "expenzen-icon.svg", class:"w-14 mb-10" %>
       <h2 class="font-bold text-slate-950 text-2xl">Change your password</h2>
        <div class="bg-white shadow rounded-lg 2xl:w-1/4 lg:w-1/3 md:w-1/2 w-full p-12 mt-10">
            <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
              <%= f.hidden_field :reset_password_token %>
              <%= render "devise/shared/error_messages", resource: resource %>
                <div>
                  <%= f.label :password, class:"text-sm font-medium leading-none text-gray-800"  %>
                   <div class="mt-2">
                     <%= f.password_field :password, autocomplete: "new-password", placeholder: '******', class:"p-2 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-300 focus:ring focus:ring-indigo-200 focus:ring-opacity-50" %>
                      <% if @minimum_password_length %>
                        <em class="text-xs text-red-600">(<%= @minimum_password_length %> characters minimum)</em>
                     <% end %>
                  </div>
                </div>

                <div class="mt-6">
                  <%= f.label :password_confirmation, class:"text-sm font-medium leading-none text-gray-800"  %>
                   <div class="mt-2">
                     <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: '******', class:"p-2 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-300 focus:ring focus:ring-indigo-200 focus:ring-opacity-50" %>
                  </div>
                </div>

                <div class="actions mt-6">
                  <%= f.submit "Change my password", class:"focus:ring-2 focus:ring-offset-2 focus:ring-indigo-700 text-sm font-semibold leading-none text-white focus:outline-none bg-indigo-700 border rounded-md hover:bg-indigo-600 py-3 w-full" %>
                </div>
              <% end %>
        </div>

        <div class="text-gray-500 text-sm mt-10">
            <%- if controller_name != 'sessions' %>
              Already have an account? <%= link_to "Sign in", new_session_path(resource_name), class: "text-indigo-600 font-semibold" %>
            <% end %>

           <div class="mt-2">
             <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
              Not a member? <%= link_to "Let's create one!", new_registration_path(resource_name), class: "text-indigo-600 font-semibold" %>
            <% end %>
          </div>
        </div>
    </div>
</div>
